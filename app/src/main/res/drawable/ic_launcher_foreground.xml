<?xml version="1.0" encoding="utf-8"?>
<!--
    Piki launcher icon foreground.
    Letter P with a heart-shaped bowl, drawn as a white thick stroke on teal background.
    Viewport 108x108. Content kept within the adaptive-icon safe zone (18–90 on each axis).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        The P is rendered as two stroked paths that share endpoints:
          1. Stem  — vertical line from foot (y=82) to top (y=26)
          2. Bowl  — heart-shaped open arc from top-of-stem (35,26)
                     curving clockwise around the bowl and ending at
                     the mid-stem connection point (35,50)

        Together they form the Piki P+heart silhouette.
    -->

    <!-- Stem: bottom foot to top -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9.5"
        android:strokeLineCap="round"
        android:pathData="M 35 82 L 35 26" />

    <!-- Heart-shaped bowl -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="
            M 35 26
            C 35 20 40 18 45 18
            C 48 17 50 17 52 18
            C 56 16 60 18 63 20
            C 72 26 78 36 76 46
            C 74 56 66 64 56 66
            C 48 68 40 64 37 57
            C 36 54 35 51 35 50
        " />

</vector>
